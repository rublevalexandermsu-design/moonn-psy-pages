{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moonn.ru/registry/products/paid-video-lectures.schema.json",
  "title": "Moonn paid video lectures manifest",
  "type": "object",
  "required": [
    "schema_version",
    "updated_at",
    "currency",
    "default_price_rub",
    "canonical_store_page",
    "lectures"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "currency": {
      "const": "RUB"
    },
    "default_price_rub": {
      "type": "integer",
      "minimum": 1
    },
    "canonical_store_page": {
      "type": "object",
      "required": ["url", "tilda_page_id", "alias", "role"],
      "properties": {
        "url": {"type": "string"},
        "tilda_page_id": {"type": "string"},
        "alias": {"type": "string"},
        "role": {"enum": ["storefront", "course_landing", "archive"]}
      }
    },
    "access_model": {
      "type": "object",
      "properties": {
        "tilda_module": {"type": "string"},
        "payment_receiver": {"type": "string"},
        "delivery_rule": {"type": "string"},
        "video_protection_rule": {"type": "string"}
      }
    },
    "lectures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "lecture_id",
          "title",
          "price_rub",
          "source_page_url",
          "status",
          "required_user_input"
        ],
        "properties": {
          "lecture_id": {"type": "string"},
          "title": {"type": "string"},
          "price_rub": {"type": "integer"},
          "source_page_url": {"type": "string"},
          "source_tilda_page_id": {"type": "string"},
          "timepad_source_url": {"type": ["string", "null"]},
          "timepad_event_id": {"type": ["string", "null"]},
          "video_source_url": {"type": ["string", "null"]},
          "tilda_product_sku": {"type": ["string", "null"]},
          "tilda_member_group": {"type": ["string", "null"]},
          "qr_image_file": {"type": ["string", "null"]},
          "protected_watch_page_url": {"type": ["string", "null"]},
          "qr_target_url": {"type": ["string", "null"]},
          "status": {
            "enum": [
              "candidate",
              "needs_video",
              "needs_tilda_product",
              "ready_for_staging",
              "staging_tested",
              "ready_for_production",
              "published"
            ]
          },
          "required_user_input": {
            "type": "array",
            "items": {"type": "string"}
          },
          "notes": {"type": "string"}
        }
      }
    }
  }
}
